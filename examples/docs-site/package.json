{
  "name": "philjs-docs",
  "version": "0.1.0",
  "description": "Official PhilJS documentation site",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@philjs/compiler": "workspace:*",
    "@philjs/core": "workspace:*",
    "@philjs/router": "workspace:*",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "shiki": "^4.0.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  }
}
