{
  "name": "marketing-site",
  "version": "0.1.0",
  "type": "module",
  "description": "PhilJS Marketing Website - Built with PhilJS",
  "scripts": {
    "dev": "tsx server/dev.ts",
    "build": "vite build && vite build --ssr src/server/entry-server.ts --outDir dist/server",
    "preview": "tsx server/prod.ts",
    "serve": "tsx server/prod.ts",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@philjs/core": "workspace:*",
    "@philjs/router": "workspace:*",
    "@philjs/ssr": "workspace:*",
    "@philjs/islands": "workspace:*",
    "@philjs/devtools": "workspace:*",
    "@philjs/compiler": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "vite": "^8.0.2",
    "vitest": "^4.1.1",
    "playwright": "^1.58.2"
  },
  "engines": {
    "node": ">=24"
  }
}
