{
  "name": "@philjs/ai",
  "version": "0.1.0",
  "description": "AI-powered code generation and analysis tools for PhilJS",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "bin": {
    "philjs-ai": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.ts",
      "import": "./dist/codegen/index.js"
    },
    "./autocomplete": {
      "types": "./dist/autocomplete/index.d.ts",
      "import": "./dist/autocomplete/index.js"
    },
    "./refactor": {
      "types": "./dist/refactor/index.d.ts",
      "import": "./dist/refactor/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    },
    "./docs": {
      "types": "./dist/docs/index.d.ts",
      "import": "./dist/docs/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./vscode": {
      "types": "./dist/vscode/extension.d.ts",
      "import": "./dist/vscode/extension.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsgo",
    "test": "vitest run",
    "lint": "npm run typecheck",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "openai": "^6.32.0",
    "ora": "^9.3.0",
    "tiktoken": "^1.0.22",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "@philjs/core": "workspace:*"
  },
  "optionalDependencies": {
    "vscode": "^1.1.37"
  },
  "license": "MIT",
  "author": "PhilJS Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-ai"
  },
  "bugs": {
    "url": "https://github.com/PhilipJohnBasile/philjs/issues"
  },
  "homepage": "https://github.com/PhilipJohnBasile/philjs#readme",
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "ai"
  ]
}
