{
  "name": "@philjs/build",
  "version": "0.1.0",
  "description": "Rspack/Rslib build toolchain for PhilJS with Module Federation support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "bin": {
    "philjs-build": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./rspack": {
      "types": "./dist/rspack/index.d.ts",
      "import": "./dist/rspack/index.js"
    },
    "./rslib": {
      "types": "./dist/rslib/index.d.ts",
      "import": "./dist/rslib/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsgo",
    "test": "vitest run",
    "lint": "npm run typecheck",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@rslib/core": "^0.20.0",
    "@rspack/core": "^1.7.9",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "vite": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "license": "MIT",
  "author": "PhilJS Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-build"
  },
  "bugs": {
    "url": "https://github.com/PhilipJohnBasile/philjs/issues"
  },
  "homepage": "https://github.com/PhilipJohnBasile/philjs#readme",
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "build",
    "rspack",
    "rslib",
    "bundler",
    "module-federation"
  ],
  "engines": {
    "node": ">=24"
  }
}
