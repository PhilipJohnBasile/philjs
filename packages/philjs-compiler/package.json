{
  "name": "@philjs/compiler",
  "version": "0.1.0",
  "description": "Automatic optimization compiler for PhilJS - zero-overhead memoization and performance optimizations",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vite": {
      "import": "./dist/plugins/vite.js",
      "types": "./dist/plugins/vite.d.ts"
    },
    "./rollup": {
      "import": "./dist/plugins/rollup.js",
      "types": "./dist/plugins/rollup.d.ts"
    },
    "./presets": {
      "import": "./dist/presets/index.js",
      "types": "./dist/presets/index.d.ts"
    },
    "./presets/production": {
      "import": "./dist/presets/production.js",
      "types": "./dist/presets/production.d.ts"
    },
    "./presets/development": {
      "import": "./dist/presets/development.js",
      "types": "./dist/presets/development.d.ts"
    },
    "./presets/library": {
      "import": "./dist/presets/library.js",
      "types": "./dist/presets/library.d.ts"
    }
  },
  "scripts": {
    "build": "tsgo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@rollup/pluginutils": "^5.3.0",
    "terser": "^5.46.1"
  },
  "devDependencies": {
    "@philjs/core": "workspace:*",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "vite": "^7.3.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "compiler",
    "optimization",
    "memoization",
    "signals",
    "reactive"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-compiler"
  },
  "bugs": {
    "url": "https://github.com/PhilipJohnBasile/philjs/issues"
  },
  "homepage": "https://github.com/PhilipJohnBasile/philjs#readme",
  "engines": {
    "node": ">=24"
  }
}
