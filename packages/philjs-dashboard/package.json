{
  "name": "@philjs/dashboard",
  "version": "0.1.0",
  "description": "Performance monitoring dashboard for PhilJS applications",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./collectors": {
      "types": "./dist/collectors/index.d.ts",
      "default": "./dist/collectors/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "dashboard",
    "performance",
    "monitoring",
    "metrics",
    "web-vitals"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-web": "^2.6.0",
    "idb": "^8.0.3",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "6.0.2",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "@philjs/core": "workspace:*"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-dashboard"
  }
}
