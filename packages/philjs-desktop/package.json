{
  "name": "@philjs/desktop",
  "version": "0.1.0",
  "description": "Desktop application development for PhilJS using Tauri",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "philjs-desktop": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tauri": {
      "types": "./dist/tauri/index.d.ts",
      "import": "./dist/tauri/index.js"
    },
    "./window": {
      "types": "./dist/window.d.ts",
      "import": "./dist/window.js"
    },
    "./system": {
      "types": "./dist/system/index.d.ts",
      "import": "./dist/system/index.js"
    },
    "./ipc": {
      "types": "./dist/ipc.d.ts",
      "import": "./dist/ipc.js"
    },
    "./lifecycle": {
      "types": "./dist/lifecycle.d.ts",
      "import": "./dist/lifecycle.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./electron": {
      "types": "./dist/electron/index.d.ts",
      "import": "./dist/electron/index.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsgo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npm run typecheck",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@philjs/core": "workspace:*",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "@tauri-apps/api": ">=2.0.0",
    "@tauri-apps/plugin-autostart": ">=2.0.0",
    "@tauri-apps/plugin-clipboard-manager": ">=2.0.0",
    "@tauri-apps/plugin-dialog": ">=2.0.0",
    "@tauri-apps/plugin-fs": ">=2.0.0",
    "@tauri-apps/plugin-global-shortcut": ">=2.0.0",
    "@tauri-apps/plugin-http": ">=2.0.0",
    "@tauri-apps/plugin-notification": ">=2.0.0",
    "@tauri-apps/plugin-os": ">=2.0.0",
    "@tauri-apps/plugin-process": ">=2.0.0",
    "@tauri-apps/plugin-shell": ">=2.0.0",
    "@tauri-apps/plugin-updater": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@tauri-apps/api": {
      "optional": true
    },
    "@tauri-apps/plugin-autostart": {
      "optional": true
    },
    "@tauri-apps/plugin-clipboard-manager": {
      "optional": true
    },
    "@tauri-apps/plugin-dialog": {
      "optional": true
    },
    "@tauri-apps/plugin-fs": {
      "optional": true
    },
    "@tauri-apps/plugin-http": {
      "optional": true
    },
    "@tauri-apps/plugin-notification": {
      "optional": true
    },
    "@tauri-apps/plugin-os": {
      "optional": true
    },
    "@tauri-apps/plugin-shell": {
      "optional": true
    },
    "@tauri-apps/plugin-global-shortcut": {
      "optional": true
    },
    "@tauri-apps/plugin-process": {
      "optional": true
    },
    "@tauri-apps/plugin-updater": {
      "optional": true
    }
  },
  "license": "MIT",
  "author": "PhilJS Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-desktop"
  },
  "bugs": {
    "url": "https://github.com/PhilipJohnBasile/philjs/issues"
  },
  "homepage": "https://github.com/PhilipJohnBasile/philjs#readme",
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "desktop",
    "tauri",
    "electron",
    "cross-platform",
    "native"
  ],
  "engines": {
    "node": ">=24"
  }
}
