{
  "name": "@philjs/docs-template",
  "version": "0.1.0",
  "engines": {
    "node": ">=24"
  },
  "description": "VitePress-like documentation template for PhilJS projects",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "philjs-docs": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@philjs/core": "workspace:*",
    "@philjs/router": "workspace:*",
    "@philjs/ssr": "workspace:*",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.5",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "6.0.2"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "docs",
    "template",
    "documentation",
    "vitepress"
  ],
  "license": "MIT",
  "author": "PhilJS Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-docs-template"
  }
