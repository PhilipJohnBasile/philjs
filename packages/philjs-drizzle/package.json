{
  "name": "@philjs/drizzle",
  "version": "0.1.0",
  "engines": {
    "node": ">=24"
  },
  "description": "Drizzle ORM adapter for PhilJS - type-safe SQL with signals",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@philjs/core": ">=0.1.0",
    "drizzle-orm": ">=0.29.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "vitest": "^4.1.1"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "drizzle",
    "orm",
    "sql",
    "database",
    "signals"
  ],
  "license": "MIT",
  "author": "PhilJS Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-drizzle"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "dependencies": {
    "@philjs/core": "workspace:*"
  }
}
