{
  "name": "@philjs/edge-mesh",
  "version": "0.1.0",
  "type": "module",
  "description": "Distributed edge consensus for PhilJS - P2P mesh networking, Raft consensus, gossip protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "edge",
    "mesh",
    "p2p",
    "consensus",
    "raft",
    "gossip",
    "distributed"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "peerDependencies": {
    "@philjs/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-edge-mesh"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false
}
