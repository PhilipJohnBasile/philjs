{
  "name": "@philjs/email",
  "version": "0.1.0",
  "description": "Email client for PhilJS - multiple providers, templates, queue integration",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./providers/*": {
      "types": "./dist/providers/*.d.ts",
      "default": "./dist/providers/*.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "email",
    "nodemailer",
    "sendgrid",
    "resend",
    "ses"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1014.0",
    "@sendgrid/mail": "^8.1.6",
    "nodemailer": "^8.0.3",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "@philjs/core": "workspace:*"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-email"
  }
}
