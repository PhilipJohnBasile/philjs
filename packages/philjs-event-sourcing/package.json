{
  "name": "@philjs/event-sourcing",
  "version": "0.1.0",
  "type": "module",
  "description": "Event sourcing with CQRS for PhilJS - event store, aggregates, projections, sagas, time-travel",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
