{
  "name": "@philjs/frontend-adapters",
  "version": "0.1.0",
  "engines": {
    "node": ">=24"
  },
  "description": "Frontend state management adapters for PhilJS (Redux, MobX, XState, Recoil)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@philjs/core": "workspace:*",
    "mobx": "^6.0.0",
    "recoil": "^0.7.0",
    "redux": "^5.0.0",
    "xstate": "^5.0.0"
  },
  "devDependencies": {
    "@philjs/core": "workspace:*",
    "@types/node": "^25.5.0",
    "vitest": "^4.1.1"
  },
  "license": "MIT",
  "author": "PhilJS Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-frontend-adapters"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "frontend",
    "adapters"
  ]
}
