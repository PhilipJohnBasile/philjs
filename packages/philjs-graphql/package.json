{
  "name": "@philjs/graphql",
  "version": "0.1.0",
  "description": "GraphQL integration for PhilJS with typed queries and mutations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsgo",
    "test": "vitest run",
    "lint": "npm run typecheck",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@philjs/core": "workspace:*",
    "@philjs/ssr": "workspace:*"
  },
  "devDependencies": {
    "@graphql-tools/schema": "^10.0.31",
    "@graphql-tools/utils": "^11.0.0",
    "graphql": "^16.13.1",
    "rollup": "^4.60.0",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "graphql": "^16.12.0"
  },
  "sideEffects": false,
  "license": "MIT",
  "author": "PhilJS Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-graphql"
  },
  "bugs": {
    "url": "https://github.com/PhilipJohnBasile/philjs/issues"
  },
  "homepage": "https://github.com/PhilipJohnBasile/philjs#readme",
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "graphql"
  ]
}
