{
  "name": "@philjs/inspector",
  "version": "0.1.0",
  "description": "Visual component inspector for PhilJS - in-page DevTools overlay",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsgo",
    "test": "vitest run",
    "lint": "npm run typecheck",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@philjs/core": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.60.0",
    "tslib": "^2.8.1",
    "vitest": "^4.1.1"
  },
  "sideEffects": false,
  "license": "MIT",
  "author": "PhilJS Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-inspector"
  },
  "bugs": {
    "url": "https://github.com/PhilipJohnBasile/philjs/issues"
  },
  "homepage": "https://github.com/PhilipJohnBasile/philjs#readme",
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "inspector"
  ]
}
