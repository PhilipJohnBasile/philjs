{
  "name": "@philjs/intent",
  "version": "0.1.0",
  "type": "module",
  "description": "Intent-based development for PhilJS - natural language to working components",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "lint": "eslint src/",
    "test": "vitest run"
