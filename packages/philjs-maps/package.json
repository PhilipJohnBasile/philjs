{
  "name": "@philjs/maps",
  "version": "0.1.0",
  "description": "Map components for PhilJS with support for Google Maps, Mapbox, and Leaflet",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./google": {
      "types": "./dist/providers/google.d.ts",
      "default": "./dist/providers/google.js"
    },
    "./mapbox": {
      "types": "./dist/providers/mapbox.d.ts",
      "default": "./dist/providers/mapbox.js"
    },
    "./leaflet": {
      "types": "./dist/providers/leaflet.d.ts",
      "default": "./dist/providers/leaflet.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "maps",
    "google-maps",
    "mapbox",
    "leaflet",
    "geolocation",
    "gis",
    "web-components"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "dependencies": {
    "leaflet": "^1.9.4",
    "mapbox-gl": "^3.20.0",
    "supercluster": "^8.0.1"
  },
  "devDependencies": {
    "@types/google.maps": "^3.58.1",
    "@types/leaflet": "^1.9.21",
    "@types/supercluster": "^7.1.3",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "@philjs/core": "workspace:*"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-maps"
  }
}
