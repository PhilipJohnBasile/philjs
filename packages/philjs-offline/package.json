{
  "name": "@philjs/offline",
  "version": "0.1.0",
  "type": "module",
  "description": "Offline-first architecture for PhilJS - IndexedDB, sync, caching strategies",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "offline",
    "indexeddb",
    "sync",
    "cache",
    "local-first",
    "pwa"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "peerDependencies": {
    "@philjs/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-offline"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false
}
