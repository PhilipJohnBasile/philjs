{
  "name": "@philjs/payments",
  "version": "0.1.0",
  "description": "Payment processing for PhilJS - Stripe, PayPal, Square support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./providers/stripe": {
      "types": "./dist/providers/stripe.d.ts",
      "default": "./dist/providers/stripe.js"
    },
    "./providers/paypal": {
      "types": "./dist/providers/paypal.d.ts",
      "default": "./dist/providers/paypal.js"
    },
    "./providers/square": {
      "types": "./dist/providers/square.d.ts",
      "default": "./dist/providers/square.js"
    },
    "./webhooks": {
      "types": "./dist/webhooks/index.d.ts",
      "default": "./dist/webhooks/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "payments",
    "stripe",
    "paypal",
    "square",
    "subscriptions"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "dependencies": {
    "@paypal/checkout-server-sdk": "^1.0.3",
    "square": "^44.0.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "@philjs/core": "workspace:*"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-payments"
  }
}
