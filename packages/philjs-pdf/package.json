{
  "name": "@philjs/pdf",
  "version": "0.1.0",
  "description": "PDF generation and manipulation for PhilJS - HTML to PDF, templates, utilities",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./templates": {
      "types": "./dist/templates/index.d.ts",
      "default": "./dist/templates/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "pdf",
    "pdf-generation",
    "puppeteer",
    "pdfkit"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "puppeteer": "^24.40.0"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.5",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "@philjs/core": "workspace:*"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-pdf"
  }
}
