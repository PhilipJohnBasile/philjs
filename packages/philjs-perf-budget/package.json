{
  "name": "@philjs/perf-budget",
  "version": "0.1.0",
  "type": "module",
  "description": "Performance budget enforcement for PhilJS - Core Web Vitals, bundle size limits, build checks",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "perf",
    "budget",
    "performance",
    "web-vitals",
    "lcp",
    "cls",
    "fid",
    "bundle-size"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "peerDependencies": {
    "@philjs/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-perf-budget"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false
}
