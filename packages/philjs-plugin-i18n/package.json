{
  "name": "@philjs/plugin-i18n",
  "version": "0.1.0",
  "description": "Internationalization plugin for PhilJS with Vite integration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run typecheck",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "plugin",
    "i18n",
    "internationalization",
    "localization",
    "l10n",
    "translations",
    "locale",
    "language"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "dependencies": {
    "@philjs/core": "workspace:*",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^4.1.1"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-plugin-i18n"
  },
  "bugs": {
    "url": "https://github.com/PhilipJohnBasile/philjs/issues"
  },
  "homepage": "https://github.com/PhilipJohnBasile/philjs#readme",
  "engines": {
    "node": ">=24"
  }
}
