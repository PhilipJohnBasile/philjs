{
  "name": "@philjs/router",
  "version": "0.1.0",
  "description": "File-based routing with nested layouts for PhilJS",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./file-based": {
      "types": "./dist/file-based/index.d.ts",
      "import": "./dist/file-based/index.js"
    },
    "./file-based/vite": {
      "types": "./dist/file-based/vite-plugin.d.ts",
      "import": "./dist/file-based/vite-plugin.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "test": "vitest run",
    "lint": "npm run typecheck",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@philjs/core": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.60.0",
    "vitest": "^4.1.1"
  },
  "sideEffects": false,
  "license": "MIT",
  "author": "PhilJS Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-router"
  },
  "bugs": {
    "url": "https://github.com/PhilipJohnBasile/philjs/issues"
  },
  "homepage": "https://github.com/PhilipJohnBasile/philjs#readme",
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "router",
    "routing",
    "navigation",
    "file-based-routing",
    "nextjs-style",
    "vite-plugin"
  ],
  "engines": {
    "node": ">=24"
  }
}
