{
  "name": "@philjs/runtime",
  "version": "0.1.0",
  "type": "module",
  "description": "PhilJS Runtime with Self-Healing capabilities - automatic error recovery, circuit breakers, hot-patching",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./self-healing": {
      "types": "./dist/self-healing/index.d.ts",
      "default": "./dist/self-healing/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "test": "vitest run"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "runtime",
    "self-healing",
    "error-recovery",
    "circuit-breaker",
    "hot-patching",
    "resilience",
    "fault-tolerance"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-runtime"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false
}
