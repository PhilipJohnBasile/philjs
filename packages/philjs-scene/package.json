{
  "name": "@philjs/scene",
  "version": "0.1.0",
  "type": "module",
  "description": "Declarative 3D scene graph for PhilJS - React-three-fiber inspired API, animations, particles, GLTF loading",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "scene",
    "3d",
    "scene-graph",
    "webgl",
    "declarative",
    "animation",
    "particles",
    "gltf"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "peerDependencies": {
    "@philjs/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-scene"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false
}
