{
  "name": "@philjs/security",
  "version": "0.1.0",
  "description": "Runtime security protection - CSP, CSRF, XSS prevention, and security headers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./csp": {
      "types": "./dist/csp.d.ts",
      "import": "./dist/csp.js",
      "require": "./dist/csp.cjs"
    },
    "./csrf": {
      "types": "./dist/csrf.d.ts",
      "import": "./dist/csrf.js",
      "require": "./dist/csrf.cjs"
    },
    "./headers": {
      "types": "./dist/headers.d.ts",
      "import": "./dist/headers.js",
      "require": "./dist/headers.cjs"
    },
    "./sanitize": {
      "types": "./dist/sanitize.d.ts",
      "import": "./dist/sanitize.js",
      "require": "./dist/sanitize.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "security",
    "csp",
    "csrf",
    "xss",
    "headers",
    "protection"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "dependencies": {
    "@philjs/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-security"
  }
}
