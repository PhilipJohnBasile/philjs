{
  "name": "@philjs/spatial-audio",
  "version": "0.1.0",
  "type": "module",
  "description": "3D spatial audio for PhilJS - HRTF, room acoustics, ambisonics, VR/AR audio sync",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "spatial",
    "audio",
    "spatial-audio",
    "3d-audio",
    "hrtf",
    "ambisonics",
    "webxr",
    "vr",
    "ar"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "peerDependencies": {
    "@philjs/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-spatial-audio"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false
}
