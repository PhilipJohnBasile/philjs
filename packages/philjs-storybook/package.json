{
  "name": "@philjs/storybook",
  "version": "0.1.0",
  "description": "Storybook integration for PhilJS - component development and testing",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./preset": {
      "types": "./dist/preset.d.ts",
      "import": "./dist/preset.js"
    },
    "./addons/signal-inspector": {
      "types": "./dist/addons/signal-inspector.d.ts",
      "import": "./dist/addons/signal-inspector.js"
    },
    "./addons/route-tester": {
      "types": "./dist/addons/route-tester.d.ts",
      "import": "./dist/addons/route-tester.js"
    },
    "./addons/theme-switcher": {
      "types": "./dist/addons/theme-switcher.d.ts",
      "import": "./dist/addons/theme-switcher.js"
    },
    "./addons/viewport": {
      "types": "./dist/addons/viewport.d.ts",
      "import": "./dist/addons/viewport.js"
    },
    "./decorators": {
      "types": "./dist/decorators/index.d.ts",
      "import": "./dist/decorators/index.js"
    },
    "./mocks": {
      "types": "./dist/mocks/index.d.ts",
      "import": "./dist/mocks/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsgo",
    "test": "vitest run",
    "lint": "npm run typecheck",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "storybook",
    "component-development",
    "testing",
    "ui"
  ],
  "dependencies": {
    "@philjs/core": "workspace:*",
    "@philjs/router": "workspace:*",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/blocks": "^8.6.14",
    "@storybook/test": "^8.6.15",
    "msw": "^2.12.14",
    "msw-storybook-addon": "^2.0.6"
  },
  "devDependencies": {
    "@storybook/core": "^8.6.14",
    "@types/node": "^25.5.0",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "storybook": "^8.0.0"
  },
  "license": "MIT",
  "author": "PhilJS Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-storybook"
  },
  "bugs": {
    "url": "https://github.com/PhilipJohnBasile/philjs/issues"
  },
  "homepage": "https://github.com/PhilipJohnBasile/philjs#readme",
  "engines": {
    "node": ">=24"
  }
}
