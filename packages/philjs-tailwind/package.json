{
  "name": "@philjs/tailwind",
  "version": "0.1.0",
  "description": "Tailwind CSS integration for PhilJS with IntelliSense and optimizations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./preset": "./dist/preset.js",
    "./plugin": "./dist/plugin.js",
    "./vite": "./dist/vite-plugin.js"
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@philjs/core": "workspace:*"
  },
  "peerDependencies": {
    "autoprefixer": "^10.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "tailwindcss": "^4.2.2"
  },
  "files": [
    "dist",
    "README.md"
