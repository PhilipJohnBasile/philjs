{
  "name": "@philjs/trpc",
  "version": "0.1.0",
  "description": "Type-safe API layer for PhilJS - RPC client/server, middleware, platform adapters",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "trpc",
    "api",
    "type-safe",
    "rpc",
    "server"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "peerDependencies": {
    "@philjs/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-trpc"
  }
}
