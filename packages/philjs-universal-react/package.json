{
  "name": "@philjs/universal-react",
  "version": "0.1.0",
  "description": "React adapter for Universal Component Protocol",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "universal",
    "react",
    "adapter",
    "cross-framework"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "dependencies": {
    "@philjs/universal": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-universal-react"
  }
}
