{
  "name": "@philjs/vector",
  "version": "0.1.0",
  "type": "module",
  "description": "Vector embeddings and RAG pipelines for PhilJS - semantic search, document chunking, hybrid search",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "vector",
    "embeddings",
    "rag",
    "semantic-search",
    "openai",
    "cohere",
    "indexeddb"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "peerDependencies": {
    "@philjs/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-vector"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false
}
