{
  "name": "@philjs/video-chat",
  "version": "0.1.0",
  "type": "module",
  "description": "Full-featured video conferencing for PhilJS - virtual backgrounds, recording, transcription, breakout rooms",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "video",
    "chat",
    "video-chat",
    "webrtc",
    "conferencing",
    "virtual-background",
    "transcription",
    "recording"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "peerDependencies": {
    "@philjs/core": "workspace:*",
    "@philjs/webrtc": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-video-chat"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false
}
