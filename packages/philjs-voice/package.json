{
  "name": "@philjs/voice",
  "version": "0.1.0",
  "type": "module",
  "description": "Voice UI primitives for PhilJS - speech recognition, synthesis, and voice commands",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "voice",
    "speech",
    "recognition",
    "synthesis",
    "voice-ui",
    "accessibility"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "peerDependencies": {
    "@philjs/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-voice"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false
}
