{
  "name": "@philjs/xr",
  "version": "0.1.0",
  "type": "module",
  "description": "WebXR Components - VR/AR/MR experiences with hand tracking, spatial UI, gestures, and 3D reactive primitives",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "test": "vitest run"
  },
  "keywords": [
    "philjs",
    "typescript",
    "framework",
    "xr",
    "webxr",
    "vr",
    "ar",
    "mr",
    "virtual-reality",
    "augmented-reality",
    "hand-tracking",
    "spatial-ui",
    "gestures",
    "immersive"
  ],
  "author": "PhilJS Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/webxr": "^0.5.24",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philjs/philjs.git",
    "directory": "packages/philjs-xr"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false
